# Credenciais globais do SaaS, usadas para cobrar planos das clinicas.
# Recebimento de sinal das clinicas fica em Dashboard > Configuracoes > Integracoes.
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=


APP_PRIMARY_HOSTS=
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID_OR_NAME=
VERCEL_TEAM_ID=
VERCEL_TEAM_SLUG=


# Credencial global da plataforma para envio de e-mail transacional.
# Destinatario/remetente de cada clinica fica em Dashboard > Configuracoes > Integracoes.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev


# Credencial global do SaaS para buscar avaliacoes reais do Google Places.
# Cada clinica informa o Place ID em Dashboard > Configuracoes > Depoimentos.
GOOGLE_MAPS_API_KEY=
